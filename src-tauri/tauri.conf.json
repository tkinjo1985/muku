{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Muku",
  "version": "0.1.0",
  "identifier": "com.takumi.muku",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Muku",
        "width": 400,
        "height": 600,
        "minWidth": 360,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["models/*.gguf", "binaries/*.dll", "binaries/*.exe"]
  }
}
